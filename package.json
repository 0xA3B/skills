{
  "name": "skills",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm lint:plugins",
    "eval:trigger": "tsx src/trigger-evals/cli.ts",
    "eval:trigger:marketplace": "tsx src/trigger-evals/cli.ts --marketplace",
    "eval:trigger:plugin": "tsx src/trigger-evals/cli.ts --plugin",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "install:frozen": "pnpm install --frozen-lockfile",
    "lint": "oxlint --deny-warnings --report-unused-disable-directives",
    "lint:fix": "oxlint --deny-warnings --report-unused-disable-directives --fix",
    "lint:plugins": "tsx src/lint-plugins/cli.ts",
    "lint:plugins:external": "tsx src/lint-plugins/cli.ts --external",
    "lint:staged": "lint-staged",
    "prepare": "husky",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@types/node": "^26.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.62.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.5",
    "yaml": "^2.8.3"
  },
  "lint-staged": {
    "*.{js,mjs,jsx,ts,tsx}": [
      "pnpm exec oxlint --deny-warnings --report-unused-disable-directives --fix",
      "pnpm exec oxfmt --write"
    ],
    "*.{json,jsonc,yaml,yml,md}": "pnpm exec oxfmt --write"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-leading-blank": [
        2,
        "always"
      ],
      "footer-leading-blank": [
        2,
        "always"
      ],
      "header-max-length": [
        2,
        "always",
        72
      ],
      "subject-case": [
        0
      ],
      "subject-full-stop": [
        2,
        "never",
        "."
      ]
    }
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
