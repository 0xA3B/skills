{
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "findings", "follow_up_questions"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "needs-attention"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "title", "body", "file", "confidence", "recommendation"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^F[1-9][0-9]*$"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "line_start": {
            "type": "integer",
            "minimum": 1
          },
          "line_end": {
            "type": "integer",
            "minimum": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "recommendation": {
            "type": "string",
            "minLength": 1
          },
          "follow_up_question": {
            "type": "string"
          }
        }
      }
    },
    "follow_up_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "session_notes": {
      "type": "string"
    }
  }
}
